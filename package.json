{
  "name": "atlasmind",
  "displayName": "AtlasMind",
  "description": "Developer-centric multi-agent orchestrator for VS Code with model routing, long-term memory, and skills registry.",
  "version": "0.38.2",
  "publisher": "JoelBondoux",
  "license": "MIT",
  "funding": {
    "type": "GitHub Sponsors",
    "url": "https://github.com/sponsors/JoelBondoux"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JoelBondoux/AtlasMind.git"
  },
  "bugs": {
    "url": "https://github.com/JoelBondoux/AtlasMind/issues"
  },
  "homepage": "https://github.com/JoelBondoux/AtlasMind#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "orchestrator",
    "multi-agent",
    "llm",
    "copilot"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:atlasmind.orchestrator"
  ],
  "main": "./out/extension.js",
  "bin": {
    "atlasmind": "./out/cli/main.js"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "atlasmind.orchestrator",
        "fullName": "AtlasMind",
        "name": "atlas",
        "description": "Multi-agent orchestrator with model routing & memory",
        "isSticky": true,
        "commands": [
          {
            "name": "bootstrap",
            "description": "Initialise a new project with SSOT memory structure"
          },
          {
            "name": "import",
            "description": "Import an existing project by scanning files and populating memory"
          },
          {
            "name": "agents",
            "description": "List or manage registered agents"
          },
          {
            "name": "skills",
            "description": "List or manage registered skills"
          },
          {
            "name": "memory",
            "description": "Query or manage the SSOT memory system"
          },
          {
            "name": "cost",
            "description": "Show cost summary for the current session"
          },
          {
            "name": "project",
            "description": "Decompose a goal into parallel subtasks and execute autonomously"
          },
          {
            "name": "voice",
            "description": "Open the Voice Panel for text-to-speech and speech-to-text"
          },
          {
            "name": "vision",
            "description": "Pick workspace images and ask a multimodal question"
          },
          {
            "name": "runs",
            "description": "Open the project run center and inspect recent autonomous runs"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "atlasmind.openGettingStarted",
        "title": "AtlasMind: Getting Started"
      },
      {
        "command": "atlasmind.openSettings",
        "title": "AtlasMind: Open Settings Panel",
        "icon": "$(gear)"
      },
      {
        "command": "atlasmind.openSettingsChat",
        "title": "AtlasMind: Open Chat Settings"
      },
      {
        "command": "atlasmind.openSettingsModels",
        "title": "AtlasMind: Open Model Settings"
      },
      {
        "command": "atlasmind.openSettingsSafety",
        "title": "AtlasMind: Open Safety Settings"
      },
      {
        "command": "atlasmind.openSettingsProject",
        "title": "AtlasMind: Open Project Settings"
      },
      {
        "command": "atlasmind.openChatPanel",
        "title": "AtlasMind: Open Chat Panel",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "atlasmind.openChatView",
        "title": "AtlasMind: Focus Chat View",
        "icon": "$(comments)"
      },
      {
        "command": "atlasmind.openModelProviders",
        "title": "AtlasMind: Manage Model Providers"
      },
      {
        "command": "atlasmind.openSpecialistIntegrations",
        "title": "AtlasMind: Specialist Integrations"
      },
      {
        "command": "atlasmind.openAgentPanel",
        "title": "AtlasMind: Manage Agents"
      },
      {
        "command": "atlasmind.agents.toggleEnabled",
        "title": "Toggle Agent Enabled",
        "icon": "$(eye)"
      },
      {
        "command": "atlasmind.agents.showDetails",
        "title": "Show Agent Details",
        "icon": "$(info)"
      },
      {
        "command": "atlasmind.bootstrapProject",
        "title": "AtlasMind: Bootstrap Project"
      },
      {
        "command": "atlasmind.importProject",
        "title": "AtlasMind: Import Existing Project",
        "icon": "$(repo-clone)"
      },
      {
        "command": "atlasmind.showCostSummary",
        "title": "AtlasMind: Show Cost Summary"
      },
      {
        "command": "atlasmind.openCostDashboard",
        "title": "AtlasMind: Open Cost Dashboard"
      },
      {
        "command": "atlasmind.toggleAutopilot",
        "title": "AtlasMind: Toggle Autopilot",
        "icon": "$(rocket)"
      },
      {
        "command": "atlasmind.skills.addSkill",
        "title": "Add Skill",
        "icon": "$(add)"
      },
      {
        "command": "atlasmind.openScannerRules",
        "title": "Configure Scanner Rules",
        "icon": "$(settings-gear)"
      },
      {
        "command": "atlasmind.skills.scan",
        "title": "Scan Skill",
        "icon": "$(shield)"
      },
      {
        "command": "atlasmind.skills.toggleEnabled",
        "title": "Toggle Skill Enabled",
        "icon": "$(eye)"
      },
      {
        "command": "atlasmind.skills.showScanResults",
        "title": "Show Scan Details"
      },
      {
        "command": "atlasmind.openMcpServers",
        "title": "AtlasMind: Manage MCP Servers",
        "icon": "$(plug)"
      },
      {
        "command": "atlasmind.models.toggleEnabled",
        "title": "Toggle Model Enabled",
        "icon": "$(eye)"
      },
      {
        "command": "atlasmind.models.openInfo",
        "title": "Open Model Info",
        "icon": "$(info)"
      },
      {
        "command": "atlasmind.models.configureProvider",
        "title": "Configure Model Provider",
        "icon": "$(settings-gear)"
      },
      {
        "command": "atlasmind.models.refreshProvider",
        "title": "Refresh Available Models",
        "icon": "$(refresh)"
      },
      {
        "command": "atlasmind.models.assignToAgent",
        "title": "Assign To Agents",
        "icon": "$(person-add)"
      },
      {
        "command": "atlasmind.openToolWebhooks",
        "title": "AtlasMind: Tool Webhooks",
        "icon": "$(broadcast)"
      },
      {
        "command": "atlasmind.openVoicePanel",
        "title": "AtlasMind: Open Voice Panel",
        "icon": "$(mic)"
      },
      {
        "command": "atlasmind.openVisionPanel",
        "title": "AtlasMind: Open Vision Panel",
        "icon": "$(device-camera)"
      },
      {
        "command": "atlasmind.openProjectRunCenter",
        "title": "AtlasMind: Open Project Run Center",
        "icon": "$(run-all)"
      },
      {
        "command": "atlasmind.memory.openEntry",
        "title": "Edit Memory File",
        "icon": "$(edit)"
      },
      {
        "command": "atlasmind.memory.showReview",
        "title": "Review Memory File",
        "icon": "$(info)"
      }
    ],
    "keybindings": [
      {
        "command": "atlasmind.openChatPanel",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "!inputFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "atlasmind.skills.addSkill",
          "when": "view == atlasmind.skillsView",
          "group": "navigation@1"
        },
        {
          "command": "atlasmind.openScannerRules",
          "when": "view == atlasmind.skillsView",
          "group": "navigation@2"
        },
        {
          "command": "atlasmind.openMcpServers",
          "when": "view == atlasmind.mcpServersView",
          "group": "navigation@1"
        },
        {
          "command": "atlasmind.openProjectRunCenter",
          "when": "view == atlasmind.projectRunsView",
          "group": "navigation@1"
        },
        {
          "command": "atlasmind.openChatView",
          "when": "view == atlasmind.sessionsView",
          "group": "navigation@1"
        },
        {
          "command": "atlasmind.openChatPanel",
          "when": "view == atlasmind.chatView",
          "group": "navigation@1"
        },
        {
          "command": "atlasmind.importProject",
          "when": "view == atlasmind.sessionsView && config.atlasmind.showImportProjectAction",
          "group": "navigation@2"
        },
        {
          "command": "atlasmind.openSettings",
          "when": "view == atlasmind.agentsView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettings",
          "when": "view == atlasmind.skillsView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettingsSafety",
          "when": "view == atlasmind.mcpServersView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettingsChat",
          "when": "view == atlasmind.sessionsView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettings",
          "when": "view == atlasmind.memoryView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettingsModels",
          "when": "view == atlasmind.modelsView",
          "group": "4_config@1"
        },
        {
          "command": "atlasmind.openSettingsProject",
          "when": "view == atlasmind.projectRunsView",
          "group": "4_config@1"
        }
      ],
      "view/item/context": [
        {
          "command": "atlasmind.agents.showDetails",
          "when": "view == atlasmind.agentsView && viewItem =~ /^agent-/",
          "group": "inline@1"
        },
        {
          "command": "atlasmind.agents.toggleEnabled",
          "when": "view == atlasmind.agentsView && viewItem =~ /^agent-/",
          "group": "inline@2"
        },
        {
          "command": "atlasmind.skills.scan",
          "when": "view == atlasmind.skillsView && viewItem =~ /^skill-/",
          "group": "inline@1"
        },
        {
          "command": "atlasmind.skills.toggleEnabled",
          "when": "view == atlasmind.skillsView && viewItem =~ /^skill-/",
          "group": "inline@2"
        },
        {
          "command": "atlasmind.skills.showScanResults",
          "when": "view == atlasmind.skillsView && viewItem =~ /^skill-/",
          "group": "2_details@1"
        },
        {
          "command": "atlasmind.memory.openEntry",
          "when": "view == atlasmind.memoryView && viewItem == memory-entry",
          "group": "inline@1"
        },
        {
          "command": "atlasmind.memory.showReview",
          "when": "view == atlasmind.memoryView && viewItem == memory-entry",
          "group": "inline@2"
        },
        {
          "command": "atlasmind.models.openInfo",
          "when": "view == atlasmind.modelsView && viewItem =~ /^model-/",
          "group": "inline@1"
        },
        {
          "command": "atlasmind.models.configureProvider",
          "when": "view == atlasmind.modelsView && viewItem =~ /^model-provider-/",
          "group": "inline@2"
        },
        {
          "command": "atlasmind.models.refreshProvider",
          "when": "view == atlasmind.modelsView && viewItem =~ /^model-provider-configured-/",
          "group": "inline@3"
        },
        {
          "command": "atlasmind.models.toggleEnabled",
          "when": "view == atlasmind.modelsView && viewItem =~ /^model-/",
          "group": "inline@4"
        },
        {
          "command": "atlasmind.models.assignToAgent",
          "when": "view == atlasmind.modelsView && viewItem =~ /^model-/",
          "group": "inline@5"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "atlasmind.getStarted",
        "title": "Get Started with AtlasMind",
        "description": "Set up your first AI-powered multi-agent workspace in four steps.",
        "steps": [
          {
            "id": "configureProvider",
            "title": "Configure a model provider",
            "description": "AtlasMind routes tasks across multiple providers and keeps search, voice, image, and video vendors on dedicated specialist surfaces.\n[Open Model Providers](command:atlasmind.openModelProviders)\n[Open Model Settings](command:atlasmind.openSettingsModels)",
            "media": {
              "markdown": "media/walkthrough/configure-provider.md"
            },
            "completionEvents": [
              "onCommand:atlasmind.openModelProviders",
              "onCommand:atlasmind.openSettingsModels"
            ]
          },
          {
            "id": "bootstrapOrImport",
            "title": "Bootstrap or import your project",
            "description": "Create the SSOT memory structure for a new project, or import context from an existing one.\n[Bootstrap Project](command:atlasmind.bootstrapProject)\n[Import Project](command:atlasmind.importProject)",
            "media": {
              "markdown": "media/walkthrough/bootstrap-import.md"
            },
            "completionEvents": [
              "onCommand:atlasmind.bootstrapProject",
              "onCommand:atlasmind.importProject"
            ]
          },
          {
            "id": "firstChat",
            "title": "Send your first message",
            "description": "Type `@atlas` in the AtlasMind chat panel followed by a question or task. AtlasMind selects the best agent and model automatically.\n[Focus Chat View](command:atlasmind.openChatView)\n[Open Chat Settings](command:atlasmind.openSettingsChat)",
            "media": {
              "markdown": "media/walkthrough/first-chat.md"
            },
            "completionEvents": [
              "onCommand:atlasmind.openChatView",
              "onCommand:atlasmind.openSettingsChat",
              "onChatParticipant:atlasmind.orchestrator"
            ]
          },
          {
            "id": "tryProject",
            "title": "Run an autonomous project",
            "description": "Use `/project <goal>` to decompose a task into parallel subtasks with preview, approval gating, cost tracking, and checkpointing.\n[Open Chat](command:atlasmind.openChatPanel)\n[Open Project Settings](command:atlasmind.openSettingsProject)",
            "media": {
              "markdown": "media/walkthrough/try-project.md"
            },
            "completionEvents": [
              "onCommand:atlasmind.openChatPanel",
              "onCommand:atlasmind.openSettingsProject",
              "onChatParticipant:atlasmind.orchestrator"
            ]
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "atlasmind.skillsView",
        "contents": "No skills registered.\n[Add a skill](command:atlasmind.skills.addSkill)"
      },
      {
        "view": "atlasmind.agentsView",
        "contents": "No agents available.\n[Open Agent Workspace](command:atlasmind.openAgentPanel)\n[Open Model Settings](command:atlasmind.openSettingsModels)"
      },
      {
        "view": "atlasmind.mcpServersView",
        "contents": "No MCP servers configured.\n[Open MCP panel](command:atlasmind.openMcpServers)\n[Open Safety Settings](command:atlasmind.openSettingsSafety)"
      },
      {
        "view": "atlasmind.modelsView",
        "contents": "No routed models configured yet.\n[Open Model Providers](command:atlasmind.openModelProviders)\n[Open Model Settings](command:atlasmind.openSettingsModels)\n[Open Specialist Integrations](command:atlasmind.openSpecialistIntegrations)"
      },
      {
        "view": "atlasmind.projectRunsView",
        "contents": "No project runs recorded yet.\n[Open Project Run Center](command:atlasmind.openProjectRunCenter)\n[Open Project Settings](command:atlasmind.openSettingsProject)"
      },
      {
        "view": "atlasmind.sessionsView",
        "contents": "No sessions yet.\n[Focus Chat View](command:atlasmind.openChatView)\n[Open Chat Settings](command:atlasmind.openSettingsChat)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atlasmind-sidebar",
          "title": "AtlasMind",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "atlasmind-sidebar": [
        {
          "id": "atlasmind.chatView",
          "name": "Chat",
          "icon": "media/icon.svg",
          "type": "webview"
        },
        {
          "id": "atlasmind.agentsView",
          "name": "Agents",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.skillsView",
          "name": "Skills",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.mcpServersView",
          "name": "MCP Servers",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.sessionsView",
          "name": "Sessions",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.memoryView",
          "name": "Memory (SSOT)",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.modelsView",
          "name": "Models",
          "icon": "media/icon.svg",
          "type": "tree"
        },
        {
          "id": "atlasmind.projectRunsView",
          "name": "Project Runs",
          "icon": "media/icon.svg",
          "type": "tree"
        }
      ]
    },
    "configuration": {
      "title": "AtlasMind",
      "properties": {
        "atlasmind.budgetMode": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "cheap",
            "balanced",
            "expensive",
            "auto"
          ],
          "description": "Budget preference for model selection."
        },
        "atlasmind.speedMode": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "fast",
            "balanced",
            "considered",
            "auto"
          ],
          "description": "Speed preference for model selection."
        },
        "atlasmind.localOpenAiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434/v1",
          "description": "Base URL for a local OpenAI-compatible model endpoint such as Ollama or LM Studio."
        },
        "atlasmind.azureOpenAiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Azure OpenAI resource endpoint used for deployment-based chat routing, for example https://your-resource.openai.azure.com."
        },
        "atlasmind.azureOpenAiDeployments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Azure OpenAI deployment names that AtlasMind should surface as routed models."
        },
        "atlasmind.bedrock.region": {
          "type": "string",
          "default": "",
          "description": "AWS region used for Amazon Bedrock model invocations, for example us-east-1."
        },
        "atlasmind.bedrock.modelIds": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Amazon Bedrock model IDs AtlasMind should expose as routed models, such as anthropic.claude-3-7-sonnet-20250219-v1:0."
        },
        "atlasmind.ssotPath": {
          "type": "string",
          "default": "project_memory",
          "description": "Relative path to the SSOT memory folder. If that path is missing, AtlasMind auto-detects an existing MindAtlas project in the current workspace when possible."
        },
        "atlasmind.showImportProjectAction": {
          "type": "boolean",
          "default": true,
          "description": "Show the Import Existing Project toolbar action in the AtlasMind Sessions view."
        },
        "atlasmind.toolApprovalMode": {
          "type": "string",
          "default": "ask-on-write",
          "enum": [
            "always-ask",
            "ask-on-write",
            "ask-on-external",
            "allow-safe-readonly"
          ],
          "description": "How AtlasMind requests approval before running tools with side effects or external execution."
        },
        "atlasmind.allowTerminalWrite": {
          "type": "boolean",
          "default": false,
          "description": "Allow write-capable terminal subprocesses such as installs and commits after explicit approval."
        },
        "atlasmind.autoVerifyAfterWrite": {
          "type": "boolean",
          "default": true,
          "description": "Run configured verification scripts after successful workspace write tools such as file-edit, file-write, and git-apply-patch."
        },
        "atlasmind.autoVerifyScripts": {
          "type": "array",
          "default": [
            "test"
          ],
          "items": {
            "type": "string"
          },
          "description": "Package scripts to run after successful write operations. Script names are sanitized and invoked without shell interpolation."
        },
        "atlasmind.autoVerifyTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "description": "Maximum time in milliseconds allowed for each automatic verification script."
        },
        "atlasmind.chatSessionTurnLimit": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "description": "How many recent chat turns AtlasMind carries forward into freeform requests."
        },
        "atlasmind.chatSessionContextChars": {
          "type": "number",
          "default": 2500,
          "minimum": 400,
          "description": "Maximum number of characters reserved for compacted session carry-forward context."
        },
        "atlasmind.projectApprovalFileThreshold": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "description": "Estimated changed-file threshold that triggers /project approval gating."
        },
        "atlasmind.projectEstimatedFilesPerSubtask": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "description": "Heuristic multiplier used to estimate changed files from the planned subtask count."
        },
        "atlasmind.projectChangedFileReferenceLimit": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Maximum number of changed files surfaced as clickable references after /project runs."
        },
        "atlasmind.projectRunReportFolder": {
          "type": "string",
          "default": "project_memory/operations",
          "description": "Relative folder for persisted /project run summary JSON reports."
        },
        "atlasmind.toolWebhookEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable outbound webhook delivery for Atlas tool execution events."
        },
        "atlasmind.toolWebhookUrl": {
          "type": "string",
          "default": "",
          "description": "HTTPS endpoint that receives Atlas tool execution webhook payloads."
        },
        "atlasmind.toolWebhookTimeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Webhook request timeout in milliseconds."
        },
        "atlasmind.toolWebhookEvents": {
          "type": "array",
          "default": [
            "tool.started",
            "tool.completed",
            "tool.failed"
          ],
          "items": {
            "type": "string",
            "enum": [
              "tool.started",
              "tool.completed",
              "tool.failed",
              "tool.test"
            ]
          },
          "description": "Selected tool webhook event names to emit."
        },
        "atlasmind.experimentalSkillLearningEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Atlas-generated custom skill drafts. Warning: this sends additional model requests and generated code still requires manual safety review."
        },
        "atlasmind.dailyCostLimitUsd": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily cost limit in USD. Set to 0 to disable. AtlasMind will warn you when 80% and 100% of this limit is reached."
        },
        "atlasmind.voice.ttsEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically speak @atlas freeform responses aloud using the Voice Panel TTS engine."
        },
        "atlasmind.voice.sttEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Show a voice input button in the Voice Panel (STT requires microphone access)."
        },
        "atlasmind.voice.rate": {
          "type": "number",
          "default": 1.0,
          "minimum": 0.5,
          "maximum": 2.0,
          "description": "Speech synthesis rate. 1.0 is normal speed; 0.5 is half speed; 2.0 is double speed."
        },
        "atlasmind.voice.pitch": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "maximum": 2.0,
          "description": "Speech synthesis pitch. 1.0 is the default pitch."
        },
        "atlasmind.voice.volume": {
          "type": "number",
          "default": 1.0,
          "minimum": 0,
          "maximum": 1.0,
          "description": "Speech synthesis volume (0 = silent, 1 = full volume)."
        },
        "atlasmind.voice.language": {
          "type": "string",
          "default": "",
          "description": "BCP 47 language tag for voice synthesis and recognition (e.g. 'en-US', 'fr-FR'). Leave empty to use the browser/OS default."
        },
        "atlasmind.maxToolIterations": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum tool-call loop iterations per agent turn."
        },
        "atlasmind.maxToolCallsPerTurn": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 30,
