#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Pre-commit: enforce version bump and changelog update

if git diff --cached --name-only | grep -qE 'src/|docs/|README.md|package.json|CONTRIBUTING.md|\.github/|wiki/'; then
  if ! git diff --cached --name-only | grep -q 'package.json'; then
    echo "ERROR: Every commit must include a version bump in package.json."
    exit 1
  fi
  if ! git diff --cached --name-only | grep -q 'CHANGELOG.md'; then
    echo "ERROR: Every commit must include a matching CHANGELOG.md entry."
    exit 1
  fi
fi
