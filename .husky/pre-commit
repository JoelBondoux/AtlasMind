# Pre-commit: enforce version bump, changelog update, and quality gate.
# Mirrors the CI quality steps (compile → lint → test) so failures are
# caught locally before push rather than discovered on the CI server.

set -e

# ── 1. Version bump + changelog enforcement ──────────────────────────────────

if git diff --cached --name-only | grep -qE 'src/|docs/|README.md|package.json|CONTRIBUTING.md|\.github/|wiki/'; then
  if ! git diff --cached --name-only | grep -q 'package.json'; then
    echo "ERROR: Every commit must include a version bump in package.json."
    exit 1
  fi
  if ! git diff --cached --name-only | grep -q 'CHANGELOG.md'; then
    echo "ERROR: Every commit must include a matching CHANGELOG.md entry."
    exit 1
  fi
fi

# ── 2. Quality gate (mirrors CI) ─────────────────────────────────────────────

echo "[pre-commit] Compiling TypeScript..."
npm run compile --silent

echo "[pre-commit] Linting..."
npm run lint --silent

echo "[pre-commit] Running tests..."
npm run test --silent

echo "[pre-commit] All checks passed."
